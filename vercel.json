{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "main.py"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "main.py"
    },
    {
      "src": "/(style.css|app.js)",
      "dest": "/public/$1"
    },
    {
      "src": "/(index.html)?",
      "dest": "/public/index.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "main.py"
    }
  ]
}
